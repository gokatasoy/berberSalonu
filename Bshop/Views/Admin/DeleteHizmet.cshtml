@model Bshop.Models.Hizmet

@{
    ViewData["Title"] = "Hizmet Sil";
}

<h2>@ViewData["Title"]</h2>

<h3>Bu hizmeti silmek istediğinize emin misiniz?</h3>

<div>
    <h4>Hizmet Bilgileri</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Hizmet Adı</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Açıklama</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Süre (dk)</dt>
        <dd class="col-sm-10">@Model.DurationMinutes</dd>
        <dt class="col-sm-2">Fiyat</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>
        <dt class="col-sm-2">Fotoğraf</dt>
        <dd class="col-sm-10">
            <img src="@Url.Content(Model.PhotoUrl)" alt="@Model.Name" width="150" />
        </dd>
    </dl>

    <form asp-action="DeleteHizmet" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Sil</button>
        <a asp-action="Hizmets" class="btn btn-secondary">İptal</a>
    </form>
</div>
