@model Bshop.Models.Salon

@{
    ViewData["Title"] = "Salon Sil";
}

<h2>@ViewData["Title"]</h2>

<h3>Bu salonu silmek istediğinize emin misiniz?</h3>

<div>
    <h4>Salon Bilgileri</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Salon Adı</dt>
        <dd class="col-sm-10">@Model.Name</dd>
    </dl>

    <form asp-action="DeleteSalon" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Sil</button>
        <a asp-action="Salons" class="btn btn-secondary">İptal</a>
    </form>
</div>
